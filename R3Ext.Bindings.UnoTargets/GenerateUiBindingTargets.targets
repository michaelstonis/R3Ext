<?xml version="1.0" encoding="UTF-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Importing project must be able to locate this assembly; when used via project reference, we build a relative path -->
  <PropertyGroup>
    <R3ExtUnoTargetsAssembly>$(MSBuildThisFileDirectory)bin/$(Configuration)/netstandard2.0/R3Ext.Bindings.UnoTargets.dll</R3ExtUnoTargetsAssembly>
  </PropertyGroup>
  <UsingTask TaskName="R3Ext.Bindings.UnoTargets.GenerateUnoUiBindingTargetsTask"
             AssemblyFile="$(R3ExtUnoTargetsAssembly)"/>
  <Target Name="GenerateUnoUiBindingTargets"
          BeforeTargets="CoreCompile"
          Condition=" '$(GenerateR3ExtUiBindingTargets)' == 'true' ">
    <ItemGroup>
      <!-- Include Uno-generated XamlCodeGenerator files -->
      <UnoGeneratedCodeFiles Include="$(IntermediateOutputPath)**/XamlCodeGenerator_*.cs"/>
      <!-- Also check for generated files in obj/gen (if EmitCompilerGeneratedFiles is enabled) -->
      <UnoGeneratedCodeFiles Include="$(MSBuildProjectDirectory)/obj/gen/**/XamlCodeGenerator_*.cs"/>
      <!-- Standard generated .g.cs files -->
      <UnoGeneratedCodeFiles Include="$(IntermediateOutputPath)**/*.g.cs"/>
      <!-- XAML files for fallback parsing -->
      <XamlFiles Include="**/*.xaml"/>
    </ItemGroup>
    <GenerateUnoUiBindingTargetsTask ProjectAssemblyName="$(AssemblyName)"
                                     IntermediateOutputPath="$(IntermediateOutputPath)"
                                     GeneratedCodeFiles="@(UnoGeneratedCodeFiles)"
                                     XamlFiles="@(XamlFiles)"/>
    <!-- Expose the emitted JSON to analyzers in this project -->
    <ItemGroup>
      <AdditionalFiles Include="$(IntermediateOutputPath)**/R3Ext.BindingTargets.json"/>
    </ItemGroup>
  </Target>
</Project>

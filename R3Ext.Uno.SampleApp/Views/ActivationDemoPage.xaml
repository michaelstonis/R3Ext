<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="R3Ext.Uno.SampleApp.Views.ActivationDemoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:R3Ext.Uno.SampleApp.Views"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="20"
                    Spacing="20">
            <TextBlock Text="R3Ext Activation Demo"
                       Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBlock Text="This page demonstrates the WhenActivated pattern with Uno Platform."
                       TextWrapping="Wrap" />

            <!-- Status Section -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Activation Status"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="StatusLabel"
                               Text="Waiting..."
                               Style="{ThemeResource BodyTextBlockStyle}" />
                </StackPanel>
            </Border>

            <!-- Timer Section -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Timer Display"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="TimerLabel"
                               Text="00:00:00"
                               Style="{ThemeResource TitleLargeTextBlockStyle}" />
                    <TextBlock x:Name="TimerStatusLabel"
                               Text="Timer stopped"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Border>

            <!-- Counters Section -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="2"
                               Text="Lifecycle Counters"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Margin="0,0,0,8" />

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Spacing="4">
                        <TextBlock Text="Activations:" />
                        <TextBlock x:Name="ActivationCountLabel"
                                   Text="0"
                                   Style="{ThemeResource TitleTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="4">
                        <TextBlock Text="Deactivations:" />
                        <TextBlock x:Name="DeactivationCountLabel"
                                   Text="0"
                                   Style="{ThemeResource TitleTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                Spacing="4"
                                Margin="0,16,0,0">
                        <TextBlock Text="Attachments:" />
                        <TextBlock x:Name="AttachmentCountLabel"
                                   Text="0"
                                   Style="{ThemeResource TitleTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="1"
                                Spacing="4"
                                Margin="0,16,0,0">
                        <TextBlock Text="Detachments:" />
                        <TextBlock x:Name="DetachmentCountLabel"
                                   Text="0"
                                   Style="{ThemeResource TitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

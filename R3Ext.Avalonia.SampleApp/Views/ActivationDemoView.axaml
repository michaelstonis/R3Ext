<?xml version="1.0" encoding="UTF-8" ?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:R3Ext.SampleApp.ViewModels"
             x:Class="R3Ext.Avalonia.SampleApp.Views.ActivationDemoView"
             x:DataType="vm:ActivationDemoViewModel">
    <Design.DataContext>
        <vm:ActivationDemoViewModel />
    </Design.DataContext>
    <ScrollViewer Padding="24">
        <StackPanel Spacing="20"
                    MaxWidth="600">
            <!-- Header -->
            <TextBlock Text="Activation Lifecycle Demo"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="This view demonstrates WhenActivated pattern with R3Ext bindings. Navigate to another page and back to see the activation/deactivation cycle."
                       FontSize="14"
                       Foreground="#666666"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
            <!-- Status Card -->
            <Border Background="#F5F5F5"
                    CornerRadius="12"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Current Status"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusLabel"
                               FontSize="16"
                               Text="Not Activated" />
                </StackPanel>
            </Border>
            <!-- Timer Card -->
            <Border Background="#E8F4E8"
                    CornerRadius="12"
                    Padding="16">
                <StackPanel Spacing="8"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Active Timer"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="TimerLabel"
                               FontSize="48"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Text="00:00" />
                    <TextBlock x:Name="TimerStatusLabel"
                               FontSize="14"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               Text="Timer stopped" />
                </StackPanel>
            </Border>
            <!-- Counters -->
            <Grid ColumnDefinitions="*,20,*">
                <Border Grid.Column="0"
                        Background="#E8E8F4"
                        CornerRadius="12"
                        Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Activations"
                                   FontSize="14"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="ActivationCountLabel"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Text="0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2"
                        Background="#F4E8E8"
                        CornerRadius="12"
                        Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Deactivations"
                                   FontSize="14"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="DeactivationCountLabel"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Text="0" />
                    </StackPanel>
                </Border>
            </Grid>
            <!-- Attachment Counters -->
            <TextBlock Text="Attachment Lifecycle (Load/Unload)"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,10,0,0" />
            <Grid ColumnDefinitions="*,20,*">
                <Border Grid.Column="0"
                        Background="#E8F0F4"
                        CornerRadius="12"
                        Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Attachments"
                                   FontSize="14"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="AttachmentCountLabel"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Text="0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2"
                        Background="#F4F0E8"
                        CornerRadius="12"
                        Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Detachments"
                                   FontSize="14"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="DetachmentCountLabel"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Text="0" />
                    </StackPanel>
                </Border>
            </Grid>
            <!-- How It Works -->
            <Border Background="#FFF8E8"
                    CornerRadius="12"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="How it works:"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock Text="1. When this view is attached to the visual tree, WhenActivated fires"
                               FontSize="14" />
                    <TextBlock Text="2. The timer starts running (only while activated)"
                               FontSize="14" />
                    <TextBlock Text="3. Navigate to 'Timer Demo' - WhenActivated cleanup runs"
                               FontSize="14" />
                    <TextBlock Text="4. Come back - WhenActivated fires again with a fresh timer"
                               FontSize="14" />
                    <TextBlock Text="5. The activation/deactivation counts track lifecycle events"
                               FontSize="14" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
